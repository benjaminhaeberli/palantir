---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const filtered = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <nav class="toc" aria-label="Sommaire de la page" data-toc>
    <p class="toc__title">Sur cette page</p>
    <ul class="toc__list">
      {filtered.map(h => (
        <li>
          <a href={`#${h.slug}`} class={`toc-depth-${h.depth}`} data-toc-link={h.slug}>
            {h.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  const setup = () => {
    const links = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('[data-toc] [data-toc-link]')
    );
    if (!links.length) return;

    const targets: HTMLElement[] = [];
    const linksById = new Map<string, HTMLAnchorElement>();
    links.forEach(link => {
      const id = link.dataset.tocLink!;
      const target = document.getElementById(id);
      if (target) {
        targets.push(target);
        linksById.set(id, link);
      }
    });

    let lastActiveId: string | null = null;

    const update = () => {
      const triggerY = window.innerHeight * 0.3;
      let activeId: string | null = targets[0]?.id ?? null;
      for (const t of targets) {
        if (t.getBoundingClientRect().top <= triggerY) activeId = t.id;
      }
      const atBottom =
        window.scrollY + window.innerHeight >=
        document.documentElement.scrollHeight - 4;
      if (atBottom) {
        activeId = targets[targets.length - 1]?.id ?? activeId;
      }
      if (activeId !== lastActiveId) {
        linksById.forEach((link, id) =>
          link.classList.toggle('is-active', id === activeId)
        );
        lastActiveId = activeId;
      }
    };

    let scheduled = false;
    const onScroll = () => {
      if (scheduled) return;
      scheduled = true;
      requestAnimationFrame(() => {
        update();
        scheduled = false;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }
</script>
