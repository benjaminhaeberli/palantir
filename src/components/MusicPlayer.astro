---
/**
 * Floating YouTube music player — bottom-right corner, in the .fab-stack.
 *
 * Comportement (calqué sur CopyTools) :
 *   • « ♪ Musique » ouvre un overlay AU-DESSUS du bouton et lance la lecture.
 *   • La pause se fait directement dans les contrôles du player YouTube.
 *   • Fermer l'overlay (×, clic extérieur, Échap) NE coupe PAS la musique :
 *     l'iframe reste chargée et continue de jouer en arrière-plan.
 *   • Un bouton « ■ » noir n'apparaît qu'une fois la lecture lancée, à droite
 *     du bouton Musique : lui seul arrête réellement la lecture.
 *
 * Pour changer la piste : éditer DEFAULT_VIDEO_ID.
 */

// Edit me — YouTube video ID (la partie après v= dans l'URL).
const DEFAULT_VIDEO_ID = 'BE6JUt9LnCw';
const TRACK_LABEL = 'Ambiance Palantír';
---

<div class="music-player" data-music-player>
  <div class="music-player__panel" data-music-panel hidden>
    <div class="music-player__header">
      <span class="music-player__track">{TRACK_LABEL}</span>
      <button
        type="button"
        class="music-player__close"
        data-music-close
        aria-label="Fermer (la musique continue)"
      >×</button>
    </div>
    <div class="music-player__iframe-slot" data-music-slot></div>
  </div>

  <div class="music-player__bar">
    <button
      type="button"
      class="music-player__toggle"
      data-music-toggle
      aria-expanded="false"
      aria-label="Ouvrir le lecteur de musique"
    >
      <span class="music-player__icon" aria-hidden="true">♪</span>
      <span class="music-player__label">Musique</span>
    </button>
    <button
      type="button"
      class="music-player__stop"
      data-music-stop
      aria-label="Arrêter la musique"
      hidden
    >
      <span aria-hidden="true">■</span>
    </button>
  </div>
</div>

<script define:vars={{ DEFAULT_VIDEO_ID }}>
  const container = document.querySelector('[data-music-player]');
  if (container) {
    const toggle = container.querySelector('[data-music-toggle]');
    const closeBtn = container.querySelector('[data-music-close]');
    const stopBtn = container.querySelector('[data-music-stop]');
    const panel = container.querySelector('[data-music-panel]');
    const slot = container.querySelector('[data-music-slot]');

    const isPlaying = () => slot.childElementCount > 0;

    const load = () => {
      slot.innerHTML = `<iframe
        width="280"
        height="60"
        src="https://www.youtube.com/embed/${DEFAULT_VIDEO_ID}?autoplay=1&loop=1&playlist=${DEFAULT_VIDEO_ID}&controls=1&modestbranding=1&rel=0"
        frameborder="0"
        allow="autoplay; encrypted-media"
        title="Musique d'ambiance"
      ></iframe>`;
      stopBtn.hidden = false;
      toggle.classList.add('is-playing');
    };

    const openPanel = () => {
      panel.hidden = false;
      toggle.setAttribute('aria-expanded', 'true');
      toggle.classList.add('is-open');
    };

    // Fermer l'overlay laisse l'iframe vivante → la musique continue.
    const closePanel = () => {
      panel.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
      toggle.classList.remove('is-open');
    };

    // Arrêt réel : on décharge l'iframe.
    const stop = () => {
      slot.innerHTML = '';
      closePanel();
      stopBtn.hidden = true;
      toggle.classList.remove('is-playing');
    };

    toggle.addEventListener('click', () => {
      if (panel.hidden) {
        if (!isPlaying()) load();
        openPanel();
      } else {
        closePanel();
      }
    });

    closeBtn.addEventListener('click', closePanel);
    stopBtn.addEventListener('click', stop);

    document.addEventListener('click', e => {
      if (!container.contains(e.target)) closePanel();
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closePanel();
    });
  }
</script>
