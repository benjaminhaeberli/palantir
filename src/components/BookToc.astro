---
import type { MarkdownHeading } from 'astro';

interface ChapterHeadings {
  id: string;
  title: string;
  headings: MarkdownHeading[];
}

interface Props {
  chapters: ChapterHeadings[];
}

const { chapters } = Astro.props;

// Pre-filter h2/h3 sub-headings per chapter so the JSX stays simple.
const items = chapters.map(c => ({
  id: c.id,
  title: c.title,
  subs: c.headings.filter(h => h.depth >= 2 && h.depth <= 3),
}));
---

<nav class="book-toc" aria-label="Sommaire complet" data-book-toc>
  <p class="toc__title">Sur cette page</p>
  <ul class="book-toc__list">
    {items.map(chapter => (
      <li class="book-toc__chapter" data-toc-chapter={chapter.id}>
        <a class="book-toc__chapter-title" href={`#${chapter.id}`} data-toc-link={chapter.id}>
          {chapter.title}
        </a>
        {chapter.subs.length > 0 && (
          <ul class="book-toc__subs">
            {chapter.subs.map(h => (
              <li>
                <a
                  href={`#${h.slug}`}
                  class={`toc-depth-${h.depth}`}
                  data-toc-link={h.slug}
                >{h.text}</a>
              </li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ul>
</nav>

<script>
  // Scroll-spy that:
  // - Highlights the currently visible section (any heading: h1/h2/h3).
  // - Marks the active *chapter* so its sub-list can be visually emphasized.
  // - Auto-scrolls the TOC column to keep the active link in view.
  // - Forces the last item active when the page is scrolled to the bottom.
  const setup = () => {
    const toc = document.querySelector<HTMLElement>('[data-book-toc]');
    if (!toc) return;

    const allLinks = Array.from(
      toc.querySelectorAll<HTMLAnchorElement>('[data-toc-link]')
    );
    if (!allLinks.length) return;

    type Entry = { id: string; el: HTMLElement; link: HTMLAnchorElement };
    const entries: Entry[] = [];
    allLinks.forEach(link => {
      const id = link.dataset.tocLink!;
      const el = document.getElementById(id);
      if (el) entries.push({ id, el, link });
    });
    if (!entries.length) return;

    // Sort by document position so that "last passed" works correctly even
    // if the TOC presents them out of order.
    entries.sort((a, b) => {
      const pos = a.el.compareDocumentPosition(b.el);
      if (pos & Node.DOCUMENT_POSITION_FOLLOWING) return -1;
      if (pos & Node.DOCUMENT_POSITION_PRECEDING) return 1;
      return 0;
    });

    let lastActiveId: string | null = null;

    const update = () => {
      const triggerY = window.innerHeight * 0.3;
      let active = entries[0];
      for (const e of entries) {
        if (e.el.getBoundingClientRect().top <= triggerY) active = e;
      }
      const atBottom =
        window.scrollY + window.innerHeight >=
        document.documentElement.scrollHeight - 4;
      if (atBottom) active = entries[entries.length - 1];

      const activeId = active.id;
      if (activeId === lastActiveId) return;

      // Active link.
      allLinks.forEach(l =>
        l.classList.toggle('is-active', l.dataset.tocLink === activeId)
      );

      // Active chapter group (so we can style its sub-list).
      const activeChapterEl = active.link.closest<HTMLElement>('[data-toc-chapter]');
      const activeChapterId = activeChapterEl?.dataset.tocChapter ?? null;
      toc.querySelectorAll<HTMLElement>('[data-toc-chapter]').forEach(ch => {
        ch.classList.toggle('is-active', ch.dataset.tocChapter === activeChapterId);
      });

      // Auto-scroll the TOC column to keep the active link visible.
      const aRect = active.link.getBoundingClientRect();
      const tRect = toc.getBoundingClientRect();
      if (aRect.top < tRect.top + 20 || aRect.bottom > tRect.bottom - 20) {
        active.link.scrollIntoView({ block: 'nearest' });
      }

      lastActiveId = activeId;
    };

    let scheduled = false;
    const onScroll = () => {
      if (scheduled) return;
      scheduled = true;
      requestAnimationFrame(() => {
        update();
        scheduled = false;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }
</script>
